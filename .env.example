# .env.example — copy this to .env and fill in your values
# NEVER commit .env — it is in .gitignore

# Maximum number of steps per episode
MAX_STEPS=5

# ROUGE-L score threshold above which episode terminates with success bonus
DONE_THRESHOLD=0.85

# Grader type: 'rouge' (no API, uses dummy outputs) or 'hf_api' (calls real LLM)
GRADER=rouge

# HuggingFace token — required only when GRADER=hf_api
# Get yours at: https://huggingface.co/settings/tokens
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxx

# HuggingFace model for Inference API (only used when GRADER=hf_api)
HF_MODEL=mistralai/Mistral-7B-Instruct-v0.2

# Fix task selection for reproducibility (integer 0–14), leave empty for random
TASK_SEED=

# Enable Gradio debug UI at /web — set to true only for local debugging
ENABLE_WEB_INTERFACE=false
