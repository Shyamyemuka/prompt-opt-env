# .env.example — copy to .env, fill real values, NEVER commit .env

# MANDATORY — verified by submission checker
API_BASE_URL=https://router.huggingface.co/v1/
API_BASE_URL_FALLBACK=https://api-inference.huggingface.co/v1/
MODEL_NAME=Qwen/Qwen2.5-72B-Instruct
OPENAI_API_KEY=
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxx

# OPTIONAL — tuning
MAX_STEPS=7
DONE_THRESHOLD=0.85
TOKEN_PENALTY_ALPHA=0.02
LLM_TIMEOUT_SECONDS=45
LLM_MAX_RETRIES=2
OPTIMIZER_FAST_MODE=false
MAX_LLM_CALLS_PER_RUN=18
MAX_RESCUE_TRIALS=10
GRADER=rouge
TASK_SEED=
ENABLE_WEB_INTERFACE=false
USE_INTELLIGENT_ACTIONS=true
ACTION_LLM_TIMEOUT_SECONDS=30
ACTION_LLM_TEMPERATURE=0.2
ACTION_LLM_MAX_CALLS=250
ACTION_LLM_DRY_RUN=false
